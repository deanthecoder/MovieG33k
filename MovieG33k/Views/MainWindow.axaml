<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:viewModels="clr-namespace:MovieG33k.ViewModels"
        mc:Ignorable="d"
        x:Name="MainWindowRoot"
        x:Class="MovieG33k.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Width="1220"
        Height="780"
        MinWidth="1040"
        MinHeight="700"
        Icon="/Assets/app.ico"
        Title="MovieG33k">
  <Grid>
    <Image Source="/Assets/main-window-bg.jpg"
           Stretch="UniformToFill" />

    <Border>
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0"
                             EndPoint="0,1">
          <GradientStop Color="#A6040B14"
                        Offset="0" />
          <GradientStop Color="#74040A13"
                        Offset="0.45" />
          <GradientStop Color="#BA040A13"
                        Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <Border Background="#1800CFFF"
            Height="260"
            VerticalAlignment="Top"
            Opacity="0.28" />

    <dialogHostAvalonia:DialogHost OverlayBackground="#AA02070D">
      <Grid Margin="28"
            RowDefinitions="Auto,Auto,Auto,Auto,*">
        <Grid ColumnDefinitions="*,Auto"
              Margin="0,8,0,18">
          <StackPanel Spacing="8">
            <TextBlock Classes="launcherEyebrow"
                       Text="RATE WHAT YOU WATCH. FIND WHAT'S NEXT." />
            <TextBlock Classes="launcherTitle"
                       FontSize="40"
                       Text="MovieG33k" />
            <TextBlock Classes="launcherHint"
                       FontSize="16"
                       TextWrapping="Wrap">
              <Run Text="Use MovieG33k to " />
              <Run Text="rate watched films" Foreground="#7CEB8B" />
              <Run Text=" and " />
              <Run Text="pick something new" Foreground="#7CEB8B" />
              <Run Text=" when you need tonight's next movie." />
            </TextBlock>
          </StackPanel>

          <Button Grid.Column="1"
                  x:Name="SettingsButton"
                  Classes="neon"
                  Width="42"
                  Height="42"
                  Padding="0"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Click="OnSettingsButtonClick"
                  ToolTip.Tip="Settings and library tools">
            <materialIcons:MaterialIcon Width="20"
                                        Height="20"
                                        Kind="CogOutline" />
            <Button.ContextMenu>
              <ContextMenu PlacementTarget="{Binding #SettingsButton}">
                <MenuItem Header="Import IMDb ratings"
                          Command="{Binding ImportImdbRatingsCommand}" />
                <MenuItem Header="Reset database"
                          Command="{Binding ResetDatabaseCommand}" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Classes="searchSurface">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
              <ComboBox MinWidth="136"
                        Margin="0,0,8,0"
                        ItemsSource="{Binding KindOptions}"
                        SelectedItem="{Binding SelectedKind, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="viewModels:DiscoveryKindOption">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBox Grid.Column="1"
                       Classes="searchBox"
                       Margin="0,0,8,0"
                       Background="Transparent"
                       BorderThickness="0"
                       FontSize="24"
                       IsVisible="{Binding !IsInsightsMode}"
                       Text="{Binding SearchText, Mode=TwoWay}"
                       Watermark="{Binding SearchWatermark}" />

              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         Classes="launcherHint"
                         FontSize="18"
                         IsVisible="{Binding IsInsightsMode}"
                         Text="Charts built from your rated library." />

              <ProgressBar Grid.Column="2"
                           Margin="0,0,12,0"
                           Width="72"
                           Height="4"
                           VerticalAlignment="Center"
                           IsIndeterminate="True"
                           IsVisible="{Binding IsBusy}"
                           Foreground="#E6F5F5F5"
                           Background="#33FFFFFF"
                           ShowProgressText="False" />

              <StackPanel Grid.Column="3"
                          Orientation="Horizontal"
                          Spacing="8">
                <Button Classes="neon"
                        Width="42"
                        Height="42"
                        Padding="0"
                        Command="{Binding ShowDiscoverCommand}"
                        IsEnabled="{Binding !IsDiscoveryMode}"
                        ToolTip.Tip="Browse movies">
                  <materialIcons:MaterialIcon Width="20"
                                              Height="20"
                                              Kind="Magnify" />
                </Button>
                <Button Classes="neon"
                        Width="42"
                        Height="42"
                        Padding="0"
                        Command="{Binding ShowRecommendedCommand}"
                        IsEnabled="{Binding !IsRecommendedMode}"
                        ToolTip.Tip="Recommended">
                  <materialIcons:MaterialIcon Width="20"
                                              Height="20"
                                              Kind="LightbulbOutline" />
                </Button>
                <Button Classes="neon"
                        Width="42"
                        Height="42"
                        Padding="0"
                        Command="{Binding ShowWatchlistCommand}"
                        IsEnabled="{Binding !IsWatchlistMode}"
                        ToolTip.Tip="Pinned to watch">
                  <materialIcons:MaterialIcon Width="20"
                                              Height="20"
                                              Kind="EyeOutline" />
                </Button>
                <Button Classes="neon"
                        Width="42"
                        Height="42"
                        Padding="0"
                        Command="{Binding ShowWatchedCommand}"
                        IsEnabled="{Binding !IsWatchedMode}"
                        ToolTip.Tip="Watched and rated">
                  <materialIcons:MaterialIcon Width="20"
                                              Height="20"
                                              Kind="StarOutline" />
                </Button>
                <Button Classes="neon"
                        Width="42"
                        Height="42"
                        Padding="0"
                        Command="{Binding ShowInsightsCommand}"
                        IsEnabled="{Binding !IsInsightsMode}"
                        ToolTip.Tip="Insights">
                  <materialIcons:MaterialIcon Width="20"
                                              Height="20"
                                              Kind="ChartPie" />
                </Button>
              </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Classes="searchSurface"
                IsVisible="{Binding HasRecommendationFilters}">
          <Grid ColumnDefinitions="Auto,Auto,*">
            <ComboBox MinWidth="180"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding RecommendationGenreOptions}"
                      SelectedItem="{Binding SelectedRecommendationGenreOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="viewModels:RecommendationFilterOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <ComboBox Grid.Column="1"
                      MinWidth="160"
                      Margin="0,0,10,0"
                      IsVisible="{Binding HasRecommendationAgeRatingFilter}"
                      ItemsSource="{Binding RecommendationAgeRatingOptions}"
                      SelectedItem="{Binding SelectedRecommendationAgeRatingOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="viewModels:RecommendationFilterOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Margin="0,0,0,12"
                    Spacing="4">
          <TextBlock Classes="launcherEyebrow"
                     FontSize="12"
                     Text="{Binding ResultsHeading}" />
          <TextBlock Classes="launcherHint"
                     Text="{Binding StatusText}" />
        </StackPanel>

        <Grid Grid.Row="4"
              IsVisible="{Binding !IsInsightsMode}"
              ColumnDefinitions="0.9*,1.1*">
          <Border Classes="resultsPanel">
            <Grid RowDefinitions="*,Auto">
              <ListBox Background="Transparent"
                       BorderThickness="0"
                       ItemsSource="{Binding Results}"
                       SelectedItem="{Binding SelectedResult, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="viewModels:LibraryItemSnapshotViewModel">
                    <Grid ColumnDefinitions="*,Auto"
                          Background="Transparent"
                          Margin="2">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="resultTitle"
                                   Text="{Binding Title}" />
                        <TextBlock Classes="resultSubtitle"
                                   Text="{Binding Subtitle}" />
                        <TextBlock Classes="launcherHint"
                                   IsVisible="{Binding HasPersonalState}"
                                   FontSize="12"
                                   Text="{Binding PersonalState}" />
                      </StackPanel>
                      <Border Grid.Column="1"
                              Margin="12,0,0,0"
                              Padding="10,4"
                              VerticalAlignment="Center"
                              CornerRadius="999"
                              Background="#2200E5FF"
                              BorderBrush="#2A3A60"
                              BorderThickness="1"
                              IsVisible="{Binding HasBadgeText}">
                        <TextBlock Classes="resultPrefix"
                                   Text="{Binding BadgeText}" />
                      </Border>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Button Grid.Row="1"
                      Margin="10,8,10,4"
                      Classes="neon"
                      HorizontalAlignment="Stretch"
                      Content="Load more"
                      Command="{Binding LoadMoreResultsCommand}"
                      IsVisible="{Binding CanLoadMore}" />
            </Grid>
          </Border>

          <ScrollViewer Grid.Column="1"
                        Margin="18,0,0,0"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Border Classes="searchSurface">
                <Grid ColumnDefinitions="Auto,*">
                  <Border Width="148"
                          Height="222"
                          CornerRadius="16"
                          Background="#101728"
                          BorderBrush="#2A3A60"
                          BorderThickness="1"
                          VerticalAlignment="Top">
                    <Grid>
                      <Image Source="{Binding SelectedPoster}"
                             Stretch="UniformToFill"
                             VerticalAlignment="Top"
                             IsVisible="{Binding HasSelectedPoster}" />
                      <TextBlock HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Classes="launcherHint"
                                 IsVisible="{Binding !HasSelectedPoster}"
                                 Text="(N/A)" />
                    </Grid>
                  </Border>

                  <StackPanel Grid.Column="1"
                              Margin="18,0,0,0"
                              Spacing="8">
                    <TextBlock Classes="launcherEyebrow"
                               FontSize="12"
                               Text="MOVIE DETAILS" />
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBox Classes="launcherTitle"
                               FontSize="30"
                               Background="Transparent"
                               BorderThickness="0"
                               IsReadOnly="True"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedTitle}" />
                      <Button Grid.Column="1"
                              Classes="neon"
                              Margin="10,0,0,0"
                              Width="36"
                              Height="36"
                              Padding="0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Command="{Binding OpenSelectedExternalLinkCommand}"
                              IsVisible="{Binding CanOpenSelectedExternalLink}"
                              ToolTip.Tip="{Binding SelectedExternalLinkToolTip}">
                        <materialIcons:MaterialIcon Width="18"
                                                    Height="18"
                                                    Kind="OpenInNew" />
                      </Button>
                    </Grid>
                    <TextBlock Classes="launcherHint"
                               Text="{Binding SelectedSubtitle}" />
                    <StackPanel Spacing="4"
                                IsVisible="{Binding HasSelectedRecommendationSignals}">
                      <TextBlock Classes="launcherEyebrow"
                                 FontSize="12"
                                 Text="WHY IT FITS" />
                      <TextBlock Classes="launcherHint"
                                 Text="{Binding SelectedPersonalState}" />
                    </StackPanel>
                    <TextBlock Classes="launcherHint"
                               IsVisible="{Binding HasSelectedRuntime}"
                               Text="{Binding SelectedRuntimeLabel}" />
                    <Button Classes="neon"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            Command="{Binding ToggleWatchlistCommand}"
                            IsVisible="{Binding CanToggleWatchlist}"
                            ToolTip.Tip="{Binding WatchlistButtonToolTip}">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8">
                        <materialIcons:MaterialIcon Width="18"
                                                    Height="18"
                                                    Kind="{Binding WatchlistButtonIcon}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding WatchlistButtonLabel}" />
                      </StackPanel>
                    </Button>
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedOverview}" />
                  </StackPanel>
                </Grid>
              </Border>

              <Border Classes="searchSurface">
                <StackPanel Spacing="12">
                  <TextBlock Classes="launcherEyebrow"
                             FontSize="12"
                             Text="RATING" />
                  <TextBlock IsVisible="{Binding HasSelectedPublicRating}"
                             Classes="launcherHint"
                             Text="{Binding SelectedPublicRatingLabel}" />
                  <TextBlock IsVisible="{Binding HasSelectedRating}"
                             Text="{Binding SelectedRatingLabel}" />
                  <StackPanel Orientation="Horizontal"
                              Spacing="8">
                    <Button MinWidth="44"
                            Classes="starButton"
                            Padding="0"
                            FontSize="24"
                            Content="{Binding Star1Glyph}"
                            Command="{Binding RateSelectedTitleCommand}"
                            CommandParameter="1" />
                    <Button MinWidth="44"
                            Classes="starButton"
                            Padding="0"
                            FontSize="24"
                            Content="{Binding Star2Glyph}"
                            Command="{Binding RateSelectedTitleCommand}"
                            CommandParameter="2" />
                    <Button MinWidth="44"
                            Classes="starButton"
                            Padding="0"
                            FontSize="24"
                            Content="{Binding Star3Glyph}"
                            Command="{Binding RateSelectedTitleCommand}"
                            CommandParameter="3" />
                    <Button MinWidth="44"
                            Classes="starButton"
                            Padding="0"
                            FontSize="24"
                            Content="{Binding Star4Glyph}"
                            Command="{Binding RateSelectedTitleCommand}"
                            CommandParameter="4" />
                    <Button MinWidth="44"
                            Classes="starButton"
                            Padding="0"
                            FontSize="24"
                            Content="{Binding Star5Glyph}"
                            Command="{Binding RateSelectedTitleCommand}"
                            CommandParameter="5" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>

        <ScrollViewer Grid.Row="4"
                      IsVisible="{Binding IsInsightsMode}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="18">
            <Grid ColumnDefinitions="*,*,*,*">
              <Border Classes="searchSurface"
                      Margin="0,0,12,0">
                <StackPanel Spacing="8">
                  <TextBlock Classes="launcherEyebrow"
                             FontSize="12"
                             Text="RATED TITLES" />
                  <TextBlock Classes="launcherTitle"
                             FontSize="28"
                             Text="{Binding TotalRatedValue}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1"
                      Classes="searchSurface"
                      Margin="0,0,12,0">
                <StackPanel Spacing="8">
                  <TextBlock Classes="launcherEyebrow"
                             FontSize="12"
                             Text="AVERAGE RATING" />
                  <TextBlock Classes="launcherTitle"
                             FontSize="28"
                             Text="{Binding AverageRatingValue}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="2"
                      Classes="searchSurface"
                      Margin="0,0,12,0">
                <StackPanel Spacing="8">
                  <TextBlock Classes="launcherEyebrow"
                             FontSize="12"
                             Text="TOP DECADE" />
                  <TextBlock Classes="launcherTitle"
                             FontSize="28"
                             Text="{Binding TopDecadeValue}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="3"
                      Classes="searchSurface">
                <StackPanel Spacing="8">
                  <TextBlock Classes="launcherEyebrow"
                             FontSize="12"
                             Text="TOP GENRE" />
                  <TextBlock Classes="launcherTitle"
                             FontSize="28"
                             Text="{Binding TopGenreValue}" />
                </StackPanel>
              </Border>
            </Grid>

            <Border Classes="searchSurface"
                    IsVisible="{Binding !HasInsights}">
              <TextBlock Classes="launcherHint"
                         FontSize="18"
                         Text="{Binding InsightsEmptyState}" />
            </Border>

            <Grid IsVisible="{Binding HasInsights}"
                  ColumnDefinitions="0.95*,1.05*">
              <Border Classes="searchSurface"
                      Margin="0,0,18,0">
                <StackPanel Spacing="14">
                  <TextBlock Classes="launcherEyebrow"
                             FontSize="12"
                             Text="RATING DISTRIBUTION" />
                  <ItemsControl ItemsSource="{Binding RatingDistribution}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="viewModels:InsightsBarViewModel">
                        <StackPanel Margin="0,0,0,10"
                                    Spacing="6">
                          <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="{Binding Label}" />
                            <TextBlock Grid.Column="2"
                                       Classes="launcherHint"
                                       Text="{Binding ValueText}" />
                          </Grid>
                          <ProgressBar Height="8"
                                       Minimum="0"
                                       Maximum="100"
                                       Value="{Binding Percent}"
                                       Foreground="#F4C94A"
                                       Background="#1AFFFFFF"
                                       ShowProgressText="False" />
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <Border Grid.Column="1"
                      Classes="searchSurface">
                <StackPanel Spacing="14">
                  <TextBlock Classes="launcherEyebrow"
                             FontSize="12"
                             Text="GENRE AVERAGES" />
                  <ItemsControl ItemsSource="{Binding RatingByGenre}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="viewModels:InsightsBarViewModel">
                        <StackPanel Margin="0,0,0,10"
                                    Spacing="6">
                          <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="{Binding Label}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ValueText}" />
                          </Grid>
                          <ProgressBar Height="8"
                                       Minimum="0"
                                       Maximum="100"
                                       Value="{Binding Percent}"
                                       Foreground="#7CEB8B"
                                       Background="#1AFFFFFF"
                                       ShowProgressText="False" />
                          <TextBlock Classes="launcherHint"
                                     FontSize="12"
                                     IsVisible="{Binding HasDetailText}"
                                     Text="{Binding DetailText}" />
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </Grid>

            <Border Classes="searchSurface"
                    IsVisible="{Binding HasInsights}">
              <StackPanel Spacing="14">
                <TextBlock Classes="launcherEyebrow"
                           FontSize="12"
                           Text="AVERAGE RATING BY DECADE" />
                <ItemsControl ItemsSource="{Binding RatingByDecade}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:InsightsBarViewModel">
                      <StackPanel Margin="0,0,0,10"
                                  Spacing="6">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                          <TextBlock Text="{Binding Label}" />
                          <TextBlock Grid.Column="2"
                                     Text="{Binding ValueText}" />
                        </Grid>
                        <ProgressBar Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding Percent}"
                                     Foreground="#53C7FF"
                                     Background="#1AFFFFFF"
                                     ShowProgressText="False" />
                        <TextBlock Classes="launcherHint"
                                   FontSize="12"
                                   IsVisible="{Binding HasDetailText}"
                                   Text="{Binding DetailText}" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </dialogHostAvalonia:DialogHost>
  </Grid>
</Window>
